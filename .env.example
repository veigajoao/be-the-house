# TxLINE API (mainnet production)
TXLINE_ENV=production
TXLINE_API_TOKEN=
# Optional: guest JWT. If absent/expired, services auto-start a new guest session.
TXLINE_JWT=

# Solana
MAINNET_RPC_URL=https://api.mainnet-beta.solana.com
ADMIN_KEYPAIR=~/.config/solana/id.json

# Test harness
SURFPOOL_BASE_PORT=18899
