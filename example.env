# ─────────────────────────────────────────────────────────────────────────────
# BeTheHouse — DEVNET configuration
#
# This is the live devnet deployment. Copy to `.env` for local dev, or paste
# these into your Vercel project settings. Nothing here has mainnet value.
#
# The server signer is resolved in this order (lib/server.ts):
#   1. DEMO_PRIVATE_KEY   (base58 — what Phantom/Solflare "export private key" gives)
#   2. DEMO_KEYPAIR_JSON  (raw [12,34,…] array — solana-keygen format)
#   3. ADMIN_KEYPAIR file path  (local dev only)
# ─────────────────────────────────────────────────────────────────────────────


# ── Network: force DEVNET ────────────────────────────────────────────────────
# "development" makes TxLineClient use the devnet feed + shows devnet UI copy.
# Leave this exactly as-is — "production" would switch to the mainnet feed.
TXLINE_ENV=development
# false = live network (here, devnet); true = local surfpool fork only.
SURFNET_MODE=false


# ── Server signer (the "operator" key) ───────────────────────────────────────
# Does the keeper cranks + faucet mint + funds users' SOL. On Vercel set ONE of
# the two below (prefer the base58 string — simplest to paste).
# ⚠ NOT your program upgrade-authority key. This key only needs: test-USDC mint
#   authority + some devnet SOL. If it leaks, worst case is minting a worthless
#   test token and spending free devnet SOL.
DEMO_PRIVATE_KEY=your_base58_private_key_here
# Alternative to the line above (either works, not both):
# DEMO_KEYPAIR_JSON=[12,34,56, ... 64 numbers ...]

# Local dev only — keypair file path, used if neither env above is set.
ADMIN_KEYPAIR=~/.config/solana/id.json


# ── RPC endpoints (devnet) ───────────────────────────────────────────────────
# Server-side RPC — keep your private/keyed QuikNode URL here (never exposed).
RPC_URL=https://your-endpoint.solana-devnet.quiknode.pro/xxxxxxxx/
DEVNET_RPC_URL=https://your-endpoint.solana-devnet.quiknode.pro/xxxxxxxx/

# Client-side RPC — baked into the browser bundle and PUBLIC.
# ⚠ Do NOT put a keyed QuikNode URL here (the key would leak). Use the public
#   devnet endpoint or a referrer-restricted one.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com


# ── Devnet mint + programs ───────────────────────────────────────────────────
NEXT_PUBLIC_USDC_MINT=ETnaYN2P3WnH1ZRgCVPbGmNsZ3g7DuJwX8t77czxAyw6
USDC_MINT=ETnaYN2P3WnH1ZRgCVPbGmNsZ3g7DuJwX8t77czxAyw6
TXORACLE_PROGRAM=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J


# ── TxLINE devnet feed credentials ───────────────────────────────────────────
# Read because TXLINE_ENV=development. The JWT expires periodically — refresh it
# if the feed starts returning 401. (The mainnet TXLINE_JWT / TXLINE_API_TOKEN
# are intentionally NOT used on devnet — don't set them here.)
TXLINE_DEV_JWT=your_txline_devnet_jwt
TXLINE_DEV_API_TOKEN=your_txline_devnet_api_token


# ── Keeper cron auth ─────────────────────────────────────────────────────────
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` to /api/cron/keeper.
# Set any random string on Vercel; requests without it are rejected.
# (Leave unset locally.)
CRON_SECRET=set_a_random_string_on_vercel


# ── Optional ─────────────────────────────────────────────────────────────────
# Restrict the fixtures shown to a single competition id (unset = all).
# COMPETITION_ID=
# Local test harness only — base port for spawned surfpool validators.
# SURFPOOL_BASE_PORT=18899
