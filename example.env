# ─────────────────────────────────────────────────────────────────────────────
# BeTheHouse — environment configuration
#
# Copy to `.env` for local dev, or set these in your Vercel project settings.
# Values below are the live DEVNET deployment. Nothing here has mainnet value.
#
# The server signer is resolved in this order (lib/server.ts):
#   1. DEMO_PRIVATE_KEY   (base58 — what Phantom/Solflare "export private key" gives)
#   2. DEMO_KEYPAIR_JSON  (raw [12,34,…] array — solana-keygen format)
#   3. ADMIN_KEYPAIR file path  (local dev only)
# ─────────────────────────────────────────────────────────────────────────────


# ── Server signer (the "operator" key: keeper + faucet mint authority + SOL bank)
# On Vercel set ONE of the two below. Prefer the base58 string — simplest to paste.
# ⚠ Do NOT use your program UPGRADE-AUTHORITY key here — keep that offline. This key
#   only needs: test-USDC mint authority + some devnet SOL (for keeper & faucet).
DEMO_PRIVATE_KEY=your_base58_private_key_here
# Alternative to the line above (either works, not both):
# DEMO_KEYPAIR_JSON=[12,34,56, ... 64 numbers ...]

# Local dev only — path to a keypair file, used if neither env above is set.
ADMIN_KEYPAIR=~/.config/solana/id.json


# ── RPC endpoints
# Server-side RPC (keep your private QuikNode URL here — never exposed to browsers).
RPC_URL=https://your-endpoint.solana-devnet.quiknode.pro/xxxxxxxx/
DEVNET_RPC_URL=https://your-endpoint.solana-devnet.quiknode.pro/xxxxxxxx/
MAINNET_RPC_URL=https://api.mainnet-beta.solana.com

# Client-side RPC — baked into the browser bundle and PUBLIC.
# ⚠ Do NOT put a keyed QuikNode URL here (the key would leak). Use a public or
#   referrer-restricted endpoint.
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com


# ── Mint / programs / network
NEXT_PUBLIC_USDC_MINT=ETnaYN2P3WnH1ZRgCVPbGmNsZ3g7DuJwX8t77czxAyw6
USDC_MINT=ETnaYN2P3WnH1ZRgCVPbGmNsZ3g7DuJwX8t77czxAyw6
TXORACLE_PROGRAM=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
# "development" = devnet (selects the TXLINE_DEV_* creds + devnet UI copy).
TXLINE_ENV=development
# false = live network (devnet/mainnet); true = local surfpool fork only.
SURFNET_MODE=false


# ── TxLINE feed credentials
# Devnet set (used when TXLINE_ENV=development). The JWT expires periodically —
# refresh it if the feed starts returning 401.
TXLINE_DEV_JWT=your_txline_devnet_jwt
TXLINE_DEV_API_TOKEN=your_txline_devnet_api_token
# Mainnet set (used when TXLINE_ENV is unset/production).
TXLINE_JWT=your_txline_mainnet_jwt
TXLINE_API_TOKEN=your_txline_mainnet_api_token


# ── Keeper cron auth
# Vercel Cron sends `Authorization: Bearer <CRON_SECRET>` to /api/cron/keeper.
# Set to any random string; requests without it are rejected. (Leave unset locally.)
CRON_SECRET=set_a_random_string_on_vercel


# ── Optional
# Restrict the fixtures shown to a single competition id (unset = all).
# COMPETITION_ID=
# Local test harness only — base port for spawned surfpool validators.
# SURFPOOL_BASE_PORT=8899
